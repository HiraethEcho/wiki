{"version": "https://jsonfeed.org/version/1", "title": "Hiraeth's Wiki", "home_page_url": "https://hiraethecho.github.io/wiki/", "feed_url": "https://hiraethecho.github.io/wiki/feed_json_updated.json", "description": "My personal wiki or PKM", "icon": null, "authors": [{"name": "hiraeth"}], "language": "en", "items": [{"id": "https://hiraethecho.github.io/wiki/blog/linux/", "url": "https://hiraethecho.github.io/wiki/blog/linux/", "title": "linux", "content_html": "<h1>linux</h1>", "image": null, "date_modified": "2025-05-17T13:30:09.625398+00:00", "authors": [], "tags": []}, {"id": "https://hiraethecho.github.io/wiki/blog/archive/2024/", "url": "https://hiraethecho.github.io/wiki/blog/archive/2024/", "title": "2024", "content_html": "<h1>2024</h1>", "image": null, "date_modified": "2025-05-17T13:30:09.622335+00:00", "authors": [], "tags": []}, {"id": "https://hiraethecho.github.io/wiki/blog/archive/2025/", "url": "https://hiraethecho.github.io/wiki/blog/archive/2025/", "title": "2025", "content_html": "<h1>2025</h1>", "image": null, "date_modified": "2025-05-17T13:30:09.619187+00:00", "authors": [], "tags": []}, {"id": "https://hiraethecho.github.io/wiki/blog/", "url": "https://hiraethecho.github.io/wiki/blog/", "title": "Blog", "content_html": "<h1>Blog</h1>", "image": null, "date_modified": "2025-05-17T13:30:09.616164+00:00", "authors": [], "tags": []}, {"id": "https://hiraethecho.github.io/wiki/", "url": "https://hiraethecho.github.io/wiki/", "title": "About", "content_html": "<h1>My online wiki</h1>\n<p>To remains me what I know and what are they.</p>\n<ul>\n<li><a href=\"/wiki/code/index\">Code</a>: My notes about code, computer and software. I use Arch by the way...</li>\n</ul>", "image": null, "date_modified": "2025-05-17T13:29:39+00:00", "authors": [], "tags": []}, {"id": "https://hiraethecho.github.io/wiki/tags/", "url": "https://hiraethecho.github.io/wiki/tags/", "title": "Tags", "content_html": "<h6>tags.md:1-23/name { #tags.md:1-23/slug }</h6>", "image":